# Copy to .env.local and fill in values. .env.local is gitignored.

# ── Gateway ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://vela:localdev@localhost:5432/vela_pulse?sslmode=disable
REDIS_URL=redis://localhost:6379/0
PORT=8080
JWT_SECRET=change-me-in-production

# ── Apple SIWA (Phase 4) ──────────────────────────────────────────────────────
APPLE_TEAM_ID=
APPLE_CLIENT_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_PATH=./secrets/authkey.p8

# ── Scraper (Phase 2) ─────────────────────────────────────────────────────────
# PROXY_TIER1_URLS=socks5://homelab:9050
# PROXY_TIER2_URLS=
# LOG_LEVEL=INFO
