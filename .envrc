# direnv — auto-loads .env.local when you cd into this directory.
# Run `direnv allow` once after cloning.
dotenv_if_exists .env.local

export DATABASE_URL="${DATABASE_URL:-postgres://vela:localdev@localhost:5432/vela_pulse?sslmode=disable}"
export REDIS_URL="${REDIS_URL:-redis://localhost:6379/0}"
export PORT="${PORT:-8080}"
export JWT_SECRET="${JWT_SECRET:-localdev-secret}"
